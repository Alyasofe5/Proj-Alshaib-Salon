# ────────────────────────────────────────────────────────────────────
# Alshaib Salon — Backend Environment Configuration (TEMPLATE)
# ────────────────────────────────────────────────────────────────────
# Copy this file to `backend/.env` and fill in the real values.
# `backend/.env` is gitignored — never commit secrets.
#
# On Hostinger:
#   1. Upload this file as `.env` (NOT .env.example) to the backend root.
#   2. Replace each placeholder below with the real value.
#   3. Make sure the file permissions are 600 (owner read/write only).
#      The .htaccess already blocks HTTP access to *.env files.
# ────────────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=your_db_name_here
DB_USER=your_db_user_here
DB_PASS=replace_with_strong_password
DB_CHARSET=utf8mb4

# ── JWT (auth) ──────────────────────────────────────────────────────
# Generate with: php -r "echo bin2hex(random_bytes(48));"
# Must be at least 32 characters. Rotating this logs out all users.
JWT_SECRET=replace_with_long_random_hex_string_min_32_chars
JWT_EXPIRY=86400

# ── App ─────────────────────────────────────────────────────────────
APP_TIMEZONE=Asia/Kuwait
