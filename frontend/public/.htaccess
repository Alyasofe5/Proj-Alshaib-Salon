RewriteEngine On

# ── Canonical: redirect www → non-www (301 permanent) ──
RewriteCond %{HTTP_HOST} ^www\.maqas\.site [NC]
RewriteRule ^(.*)$ https://maqas.site/$1 [R=301,L]

# ── Force HTTPS ──
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── DirectoryIndex: prevent Apache redirect on bare directory API URLs ──
# Without this, GET/OPTIONS /api/employees (no slash) triggers a 301 redirect
# which browsers block for CORS preflight requests.
DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
    # Internally rewrite /api/<name> (no trailing slash, no extension) → /api/<name>/index.php
    # This prevents Apache's "directory" 301 redirect from stripping CORS headers.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^(api/.+[^/])$ /$1/index.php [L]
</IfModule>

# ── Deny access to sensitive directories and config files ──
<IfModule mod_rewrite.c>
    RewriteRule ^config/ - [F,L]
    RewriteRule ^middleware/ - [F,L]
</IfModule>

<FilesMatch "\.(env|ini|log|sh|sql)$">
    Require all denied
</FilesMatch>

# ── Security Headers ──
<IfModule mod_headers.c>
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>

# ── Cache Control: no-cache for HTML pages (always serve fresh) ──
<FilesMatch "\.(html|htm)$">
    <IfModule mod_headers.c>
        Header always set Cache-Control "no-cache, no-store, must-revalidate"
        Header always set Expires "0"
    </IfModule>
</FilesMatch>

# ── Long-term cache for hashed static assets (JS/CSS with hash in name) ──
<FilesMatch "\.(js|css|png|jpg|jpeg|gif|ico|woff|woff2|svg|webp)$">
    <IfModule mod_headers.c>
        Header always set Cache-Control "public, max-age=31536000, immutable"
    </IfModule>
</FilesMatch>

# ── Persistent File Server: route /uploads/ → PHP file server ──
# Files are stored ABOVE public_html in user_uploads/ (survives deploys)
<IfModule mod_rewrite.c>
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^uploads/(.+)$ /api/file-server.php?path=$1 [QSA,L]
</IfModule>

# ── SPA Fallback: serve specific index.html for sub-routes ──
<IfModule mod_rewrite.c>
    # 1. If it's a physical file, directory, or an API/Uploads route, stop processing SPA rules here.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d [OR]
    RewriteCond %{REQUEST_URI} ^/(api|uploads)/
    RewriteRule ^ - [L]
    
    # 2. Redirect dynamic routes to use query strings (Next.js static export fix)
    # Next.js App Router static exports crash on unbuilt catch-all URLs when fetching RSC payloads.
    # We redirect them to the root of the exported page, which handles the query param purely client-side.
    RewriteRule ^book/([^/]+)/?$ /book/?s=$1 [R=301,L,QSA]
    RewriteRule ^admin/([^/]+)/?$ /admin/?s=$1 [R=301,L,QSA]
    RewriteRule ^employee/([^/]+)/?$ /employee/?s=$1 [R=301,L,QSA]
    RewriteRule ^superadmin/([^/]+)/?$ /superadmin/?s=$1 [R=301,L,QSA]
    
    # 3. Serve specific index.html for base routes
    RewriteRule ^book/?$ /book/index.html [L]
    RewriteRule ^admin/?$ /admin/index.html [L]
    RewriteRule ^employee/?$ /employee/index.html [L]
    RewriteRule ^superadmin/?$ /superadmin/index.html [L]
    
    # 3. Everything else goes to the main app index.html
    RewriteRule ^(.*)$ /index.html [L]
</IfModule>

# ── Disable LiteSpeed Cache for API responses ──
<IfModule LiteSpeed>
    CacheLookup off
</IfModule>
