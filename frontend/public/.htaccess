<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Redirect any request to /book/* (folder that doesn't exist) to /book/index.html
  # This makes dynamic slugs work in a Static Export on Apache/Hostinger
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^book/.*$ book/index.html [L]

  # Regular Next.js static handling
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . index.html [L]
</IfModule>
